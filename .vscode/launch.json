    },
    {
      "name": "Flutter (Chrome Debug)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "toolArgs": [
        "--frontend-server-starter-path",
        "tool/flutter_web_frontend_server_starter.dart"
      ]
    },
    {
      "name": "Flutter (Windows Debug)",
      "request": "launch",
      "type": "dart",
      "deviceId": "windows"
    },
    {
      "name": "Flutter (Profile, Selected Device)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile"
    }
  ]
